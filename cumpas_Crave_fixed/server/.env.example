# Example for running against a LOCAL PostgreSQL instance.
# Copy this to .env and adjust user/password/db name to match your local setup.

# Local Postgres connection (no SSL needed — auto-detected from "localhost")
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/campus_crave

PORT=4000
NODE_ENV=development
JWT_SECRET=campus_crave_secret_2024
JWT_EXPIRES_IN=7d

# Only needed if you deploy behind a proxy/tunnel with a different frontend origin
FRONTEND_URL=http://localhost:3000

# Optional: override SSL behavior manually. Leave unset to let the app
# auto-detect (disabled for localhost/127.0.0.1, enabled otherwise).
# PGSSL=false

# Optional: override the mock online-payment password (default: 123456)
# MOCK_PAYMENT_PASSWORD=123456
